<Window x:Class="ScadaGUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podesavanja (tema i zvuk)" Height="360" Width="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="Tema:" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
            <RadioButton x:Name="LightRadio" Content="Light" GroupName="Theme" Margin="0,0,16,0" Checked="Theme_Changed"/>
            <RadioButton x:Name="DarkRadio" Content="Dark" GroupName="Theme" Checked="Theme_Changed"/>
        </StackPanel>

        <TextBlock Text="Zvuk alarma:" FontWeight="Bold"/>
        <ComboBox x:Name="SoundCombo" Margin="0,4,0,10"/>

        <TextBlock Text="Jacina zvuka:" FontWeight="Bold"/>
        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Margin="0,4,0,10" ValueChanged="Volume_Changed"/>

        <StackPanel Orientation="Horizontal">
            <Button Content="Testiraj zvuk" Click="TestSound_Click" Width="110" Height="30" Margin="0,0,8,0"/>
            <Button Content="Stop" Click="StopSound_Click" Width="70" Height="30"/>
        </StackPanel>

        <Button Content="Zatvori" Click="Close_Click" Height="30" Margin="0,16,0,0"/>
    </StackPanel>
</Window>
