<local:DialogWindow xmlns:local="clr-namespace:ScadaGUI" x:Class="ScadaGUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podesavanja / Settings" Height="620" Width="420"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <TextBlock Text="Tema:" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                <RadioButton x:Name="LightRadio" Content="Light" GroupName="Theme" Margin="0,0,16,0" Checked="Theme_Changed"/>
                <RadioButton x:Name="DarkRadio" Content="Dark" GroupName="Theme" Checked="Theme_Changed"/>
            </StackPanel>

            <TextBlock Text="Zvuk alarma:" FontWeight="Bold"/>
            <ComboBox x:Name="SoundCombo" Margin="0,4,0,10"/>

            <TextBlock Text="Jacina zvuka:" FontWeight="Bold"/>
            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Margin="0,4,0,10" ValueChanged="Volume_Changed"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Testiraj zvuk" Click="TestSound_Click" Width="110" Height="30" Margin="0,0,8,0"/>
                <Button Content="Stop" Click="StopSound_Click" Width="70" Height="30"/>
            </StackPanel>

            <TextBlock Text="Jezik / Language:" FontWeight="Bold"/>
            <ComboBox x:Name="LangCombo" Margin="0,4,0,10" SelectionChanged="Lang_Changed">
                <ComboBoxItem Content="Srpski"/>
                <ComboBoxItem Content="English"/>
            </ComboBox>

            <TextBlock Text="Format datuma:" FontWeight="Bold"/>
            <ComboBox x:Name="DateFormatCombo" Margin="0,4,0,10" SelectionChanged="DateFormat_Changed">
                <ComboBoxItem Content="yyyy-MM-dd HH:mm:ss"/>
                <ComboBoxItem Content="dd.MM.yyyy. HH:mm:ss"/>
                <ComboBoxItem Content="MM/dd/yyyy hh:mm tt"/>
            </ComboBox>

            <TextBlock Text="Vremenska zona:" FontWeight="Bold"/>
            <ComboBox x:Name="TimeZoneCombo" Margin="0,4,0,10" SelectionChanged="TimeZone_Changed"/>

            <Button Content="Zatvori / Close" Click="Close_Click" Height="30" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</local:DialogWindow>
