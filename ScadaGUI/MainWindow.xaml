<Window x:Class="ScadaGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ScadaGUI.Converters"
        Title="SCADA Aplikacija" Height="500" Width="920"
        Closing="Window_Closing">
    <Window.Resources>
        <conv:AlarmStatusToBrushConverter x:Key="AlarmBrush"/>
    </Window.Resources>
    <DockPanel>
        <WrapPanel DockPanel.Dock="Bottom" Margin="8">
            <Button x:Name="AddBtn" Content="Dodaj" Click="Add_Click" Width="90" Height="30" Margin="4"/>
            <Button x:Name="RemoveBtn" Content="Ukloni" Click="Remove_Click" Width="90" Height="30" Margin="4"/>
            <Button x:Name="WriteBtn" Content="Upisi vrednost" Click="WriteValue_Click" Width="110" Height="30" Margin="4"/>
            <Button Content="Detalji" Click="Details_Click" Width="90" Height="30" Margin="4"/>
            <Button x:Name="ScanBtn" Content="Scan on/off" Click="ToggleScan_Click" Width="100" Height="30" Margin="4"/>
            <Button x:Name="AckBtn" Content="Acknowledge" Click="Acknowledge_Click" Width="100" Height="30" Margin="4"/>
            <Button Content="Report" Click="Report_Click" Width="90" Height="30" Margin="4"/>
            <Button x:Name="TraceBtn" Content="Trace log" Click="TraceSettings_Click" Width="90" Height="30" Margin="4"/>
            <Button Content="Export" Click="Export_Click" Width="80" Height="30" Margin="4"/>
            <Button x:Name="ImportBtn" Content="Import" Click="Import_Click" Width="80" Height="30" Margin="4"/>
            <Button Content="Pretraga" Click="Filter_Click" Width="90" Height="30" Margin="4"/>
            <Button Content="Opcije" Click="Settings_Click" Width="80" Height="30" Margin="4"/>
        </WrapPanel>
        <DataGrid x:Name="TagsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" Margin="8">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding Converter={StaticResource AlarmBrush}}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tip" Binding="{Binding Type}" Width="60"/>
                <DataGridTextColumn Header="Naziv" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="Adresa" Binding="{Binding IOAddress}" Width="100"/>
                <DataGridTextColumn Header="Vrednost" Binding="{Binding CurrentValue}" Width="120"/>
                <DataGridTextColumn Header="Jedinica" Binding="{Binding Units}" Width="100"/>
                <DataGridTextColumn Header="Opis" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
