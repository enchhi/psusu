<Window x:Class="ScadaGUI.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ScadaGUI.Converters"
        Title="Pretraga AI vrednosti (baza)" Height="520" Width="660"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <conv:TimeConverter x:Key="TimeConv"/>
    </Window.Resources>
    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ime taga:" VerticalAlignment="Center" Margin="0,3,8,3"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TagBox" Margin="0,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Vreme od:" VerticalAlignment="Center" Margin="0,3,8,3"/>
            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="FromBox" Margin="0,3"/>
            <TextBlock Grid.Row="1" Grid.Column="2" Text="Vreme do:" VerticalAlignment="Center" Margin="12,3,8,3"/>
            <TextBox   Grid.Row="1" Grid.Column="3" x:Name="ToBox" Margin="0,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Vrednost od:" VerticalAlignment="Center" Margin="0,3,8,3"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="MinBox" Margin="0,3"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Vrednost do:" VerticalAlignment="Center" Margin="12,3,8,3"/>
            <TextBox   Grid.Row="2" Grid.Column="3" x:Name="MaxBox" Margin="0,3"/>
        </Grid>

        <TextBlock DockPanel.Dock="Top" Foreground="Gray" Margin="0,6,0,6"
                   Text="Format vremena: yyyy-MM-dd HH:mm:ss. Prazno polje = uslov se ignorise."/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="Mock" Click="Mock_Click" Width="80" Height="30" Margin="4"/>
            <Button Content="Pretrazi" Click="Search_Click" Width="90" Height="30" Margin="4"/>
            <Button Content="Generate TXT" Click="GenerateTxt_Click" Width="120" Height="30" Margin="4"/>
        </StackPanel>

        <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,8,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ime taga" Binding="{Binding TagName}" Width="180"/>
                <DataGridTextColumn Header="Vreme" Binding="{Binding Timestamp, Converter={StaticResource TimeConv}}" Width="200"/>
                <DataGridTextColumn Header="Vrednost" Binding="{Binding Value}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
