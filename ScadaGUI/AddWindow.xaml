<Window x:Class="ScadaGUI.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj tag / alarm" Height="560" Width="420"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14">
            <TextBlock Text="Tip:" FontWeight="Bold"/>
            <ComboBox x:Name="TypeCombo" SelectionChanged="TypeCombo_SelectionChanged" Margin="0,2,0,10">
                <ComboBoxItem Content="AI"/>
                <ComboBoxItem Content="AO"/>
                <ComboBoxItem Content="DI"/>
                <ComboBoxItem Content="DO"/>
                <ComboBoxItem Content="Alarm"/>
            </ComboBox>

            <!-- Zajednicka polja za tagove -->
            <StackPanel x:Name="CommonPanel">
                <TextBlock Text="Naziv (Name):"/>
                <TextBox x:Name="NameBox"/>
                <TextBlock Text="Opis (Description):" Margin="0,6,0,0"/>
                <TextBox x:Name="DescBox"/>
                <TextBlock Text="Adresa (IOAddress):" Margin="0,6,0,0"/>
                <ComboBox x:Name="AddressCombo"/>
            </StackPanel>

            <!-- Ulazna polja (AI / DI) -->
            <StackPanel x:Name="InputPanel">
                <TextBlock Text="Scan time (ms):" Margin="0,6,0,0"/>
                <TextBox x:Name="ScanTimeBox"/>
                <CheckBox x:Name="OnScanBox" Content="On scan" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Analogna polja (AI / AO) -->
            <StackPanel x:Name="AnalogPanel">
                <TextBlock Text="Low limit:" Margin="0,6,0,0"/>
                <TextBox x:Name="LowBox"/>
                <TextBlock Text="High limit:" Margin="0,6,0,0"/>
                <TextBox x:Name="HighBox"/>
                <TextBlock Text="Units:" Margin="0,6,0,0"/>
                <TextBox x:Name="UnitsBox"/>
            </StackPanel>

            <!-- Samo AI -->
            <StackPanel x:Name="AiPanel">
                <TextBlock Text="Deadband:" Margin="0,6,0,0"/>
                <TextBox x:Name="DeadbandBox"/>
                <TextBlock Text="Hysteresis:" Margin="0,6,0,0"/>
                <TextBox x:Name="HystBox"/>
            </StackPanel>

            <!-- Izlazna polja (AO / DO) -->
            <StackPanel x:Name="OutputPanel">
                <TextBlock Text="Initial value:" Margin="0,6,0,0"/>
                <TextBox x:Name="InitialBox"/>
            </StackPanel>

            <!-- Alarm polja -->
            <StackPanel x:Name="AlarmPanel">
                <TextBlock Text="AI tag:"/>
                <ComboBox x:Name="AlarmAiCombo"/>
                <TextBlock Text="Granica (Limit):" Margin="0,6,0,0"/>
                <TextBox x:Name="LimitBox"/>
                <TextBlock Text="Smer:" Margin="0,6,0,0"/>
                <ComboBox x:Name="DirectionCombo">
                    <ComboBoxItem Content="Above"/>
                    <ComboBoxItem Content="Below"/>
                </ComboBox>
                <TextBlock Text="Poruka:" Margin="0,6,0,0"/>
                <TextBox x:Name="AlarmMessageBox"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Mock" Click="Mock_Click" Width="120" Height="32" Margin="0,0,8,0"/>
                <Button Content="Sacuvaj" Click="Save_Click" Width="160" Height="32"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
