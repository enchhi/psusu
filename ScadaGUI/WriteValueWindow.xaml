<local:DialogWindow xmlns:local="clr-namespace:ScadaGUI" x:Class="ScadaGUI.WriteValueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upis vrednosti" Height="170" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="12">
        <TextBlock x:Name="InfoText" TextWrapping="Wrap"/>
        <TextBox x:Name="ValueBox" Margin="0,8,0,8"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="Mock" Click="Mock_Click" Width="90" Height="30" Margin="0,0,8,0"/>
            <Button Content="Upisi" Click="Write_Click" Width="188" Height="30"/>
        </StackPanel>
    </StackPanel>
</local:DialogWindow>
