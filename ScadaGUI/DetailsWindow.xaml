<local:DialogWindow xmlns:local="clr-namespace:ScadaGUI" x:Class="ScadaGUI.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalji - AI" Height="480" Width="840"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock x:Name="StatsText" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock x:Name="AlarmsLabel" DockPanel.Dock="Top" Text="Alarmi:" FontWeight="Bold" Margin="0,0,0,4"/>
            <Button x:Name="RemoveAlarmBtn" DockPanel.Dock="Bottom" Content="Ukloni alarm"
                    Height="30" Margin="0,8,0,0" Click="RemoveAlarm_Click"/>
            <DataGrid x:Name="AlarmsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="LimitColumn" Header="Granica" Binding="{Binding LimitValue}"/>
                    <DataGridTextColumn x:Name="DirectionColumn" Header="Smer" Binding="{Binding Direction}"/>
                    <DataGridTextColumn x:Name="MessageColumn" Header="Poruka" Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn x:Name="StateColumn" Header="Stanje" Binding="{Binding State}"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
            <Canvas x:Name="ChartCanvas" Background="{DynamicResource SurfaceBrush}" ClipToBounds="True"/>
        </Border>
    </Grid>
</local:DialogWindow>
