<Window x:Class="ScadaGUI.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalji - AI" Height="480" Width="840"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock x:Name="StatsText" DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock DockPanel.Dock="Top" Text="Alarmi:" FontWeight="Bold" Margin="0,0,0,4"/>
            <DataGrid x:Name="AlarmsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Granica" Binding="{Binding LimitValue}"/>
                    <DataGridTextColumn Header="Smer" Binding="{Binding Direction}"/>
                    <DataGridTextColumn Header="Poruka" Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn Header="Stanje" Binding="{Binding State}"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1">
            <Canvas x:Name="ChartCanvas" Background="White" ClipToBounds="True"/>
        </Border>
    </Grid>
</Window>
