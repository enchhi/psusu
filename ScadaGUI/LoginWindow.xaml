<Window x:Class="ScadaGUI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SCADA - Prijava" Height="300" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="SCADA - Prijava" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <TextBlock Text="Korisnicko ime:"/>
        <TextBox x:Name="UsernameBox" Margin="0,2,0,8"/>

        <TextBlock Text="Lozinka:"/>
        <PasswordBox x:Name="PassBox" Margin="0,2,0,8"/>

        <TextBlock Text="Uloga:"/>
        <ComboBox x:Name="RoleCombo" Margin="0,2,0,12">
            <ComboBoxItem Content="Admin"/>
            <ComboBoxItem Content="Operater"/>
            <ComboBoxItem Content="Student"/>
            <ComboBoxItem Content="Teacher"/>
        </ComboBox>

        <Button Content="Prijava" Click="Login_Click" Height="32" IsDefault="True"/>

        <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,10,0,0"
                   Text="Novo korisnicko ime = registracija. Lozinka: min 15 karaktera, bar jedno veliko i malo slovo i specijalni karakter; ne sme postojati ista lozinka u bazi."/>
    </StackPanel>
</Window>
